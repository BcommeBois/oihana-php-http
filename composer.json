{
    "name" : "oihana/php-http" ,
    "type" : "library" ,
    "description" : "Composable PHP HTTP toolkit — client IP detection (X-Forwarded-For chain walking + CIDR + IPv4/IPv6), typed Set-Cookie header builders, signed URLs, content negotiation, user-agent parsing. PSR-7 compatible, zero magic strings." ,
    "keywords" : [
        "php" ,
        "http" ,
        "psr-7" ,
        "ip" ,
        "x-forwarded-for" ,
        "cidr" ,
        "cookies" ,
        "set-cookie" ,
        "samesite" ,
        "user-agent" ,
        "signed-url" ,
        "content-negotiation"
    ] ,
    "homepage" : "https://github.com/BcommeBois/oihana-php-http" ,
    "license" : "MPL-2.0" ,
    "authors" : [
        {
            "name"     : "Marc Alcaraz" ,
            "email"    : "marc@ooop.fr" ,
            "homepage" : "https://www.ooop.fr" ,
            "role"     : "Project Founder, Lead Developer."
        }
    ] ,
    "support" : {
        "email"  : "marc@ooop.fr" ,
        "issues" : "https://github.com/BcommeBois/oihana-php-http/issues" ,
        "source" : "https://github.com/BcommeBois/oihana-php-http"
    } ,
    "scripts" : {
        "doc"  : "rm -rf docs && mkdir docs && cp -r assets docs/assets && ./vendor/bin/phpdoc -c phpdoc.xml -v" ,
        "test" : "./vendor/bin/phpunit" ,
        "coverage" : "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html" ,
        "coverage:md" : [
            "@coverage" ,
            "php tools/clover-to-markdown.php build/coverage/clover.xml build/coverage/COVERAGE.md"
        ]
    } ,
    "autoload" : {
        "psr-4" : {
            "oihana\\http\\" : "src/oihana/http"
        } ,
        "files" : [
            "src/oihana/http/helpers/detectUserAgentBot.php" ,
            "src/oihana/http/helpers/detectUserAgentBrowser.php" ,
            "src/oihana/http/helpers/detectUserAgentDeviceType.php" ,
            "src/oihana/http/helpers/detectUserAgentOs.php" ,
            "src/oihana/http/helpers/getUserAgent.php" ,
            "src/oihana/http/helpers/isBotUserAgent.php" ,
            "src/oihana/http/helpers/isMobileUserAgent.php" ,
            "src/oihana/http/helpers/parseUserAgent.php" ,


            "src/oihana/http/helpers/auth/getBasicAuth.php" ,
            "src/oihana/http/helpers/auth/getBearerToken.php" ,
            "src/oihana/http/helpers/auth/parseAuthorizationHeader.php" ,

            "src/oihana/http/helpers/dates/formatHttpDate.php" ,
            "src/oihana/http/helpers/dates/parseHttpDate.php" ,

            "src/oihana/http/helpers/request/isAjax.php" ,
            "src/oihana/http/helpers/request/isHttpsRequest.php" ,
            "src/oihana/http/helpers/request/wantsJson.php" ,

            "src/oihana/http/helpers/negotiation/negotiate.php" ,
            "src/oihana/http/helpers/negotiation/parseAcceptHeader.php" ,
            "src/oihana/http/helpers/negotiation/parseContentType.php" ,

            "src/oihana/http/helpers/url/buildQueryString.php" ,
            "src/oihana/http/helpers/url/getHost.php" ,
            "src/oihana/http/helpers/url/isAbsoluteUrl.php" ,
            "src/oihana/http/helpers/url/isLocalUrl.php" ,
            "src/oihana/http/helpers/url/isPublicUrl.php" ,
            "src/oihana/http/helpers/url/normalizeUrl.php" ,
            "src/oihana/http/helpers/url/parseQueryString.php" ,
            "src/oihana/http/helpers/url/reassembleUrl.php" ,
            "src/oihana/http/helpers/url/removeQueryParam.php" ,
            "src/oihana/http/helpers/url/withQueryParams.php" ,
            "src/oihana/http/helpers/url/withUrlComponents.php" ,

            "src/oihana/http/helpers/signatures/signUrl.php" ,
            "src/oihana/http/helpers/signatures/verifyHmacSignature.php" ,
            "src/oihana/http/helpers/signatures/verifySignedUrl.php" ,

            "src/oihana/http/helpers/cookies/buildSetCookieHeader.php" ,
            "src/oihana/http/helpers/cookies/expireSetCookieHeader.php" ,
            "src/oihana/http/helpers/cookies/parseCookieHeader.php" ,
            "src/oihana/http/helpers/cookies/parseSetCookieHeader.php" ,
            "src/oihana/http/helpers/cookies/validateCookieName.php" ,
            "src/oihana/http/helpers/cookies/validateCookieValue.php" ,
            
            "src/oihana/http/helpers/ips/acceptIp.php" ,
            "src/oihana/http/helpers/ips/anonymizeIp.php" ,
            "src/oihana/http/helpers/ips/canonicalIp.php" ,
            "src/oihana/http/helpers/ips/extractIpCandidatesFromGlobals.php" ,
            "src/oihana/http/helpers/ips/extractIpCandidatesFromRequest.php" ,
            "src/oihana/http/helpers/ips/getClientIp.php" ,
            "src/oihana/http/helpers/ips/ipInList.php" ,
            "src/oihana/http/helpers/ips/ipMatchesCidr.php" ,
            "src/oihana/http/helpers/ips/isPublicIp.php" ,
            "src/oihana/http/helpers/ips/parseForwardedHeader.php" ,
            "src/oihana/http/helpers/ips/truncateIpToSlash24.php" ,
            "src/oihana/http/helpers/ips/truncateIpToSlash48.php" ,
            "src/oihana/http/helpers/ips/walkForwardedChain.php"
        ]
    } ,
    "autoload-dev" : {
        "psr-4" : {
            "tests\\oihana\\http\\" : "tests/oihana/http"
        }
    } ,
    "require" : {
        "php"                  : ">=8.4" ,
        "psr/http-message"     : "^2.0" ,
        "oihana/php-core"      : "dev-main" ,
        "oihana/php-enums"     : "dev-main" ,
        "oihana/php-files"     : "dev-main" ,
        "oihana/php-reflect"   : "dev-main" ,
        "oihana/php-schema"    : "dev-main" ,
        "oihana/php-standards" : "dev-main"
    } ,
    "require-dev" : {
        "phpunit/phpunit"      : "^12" ,
        "nunomaduro/collision" : "^8.8" ,
        "phpdocumentor/shim"   : "^3.8" ,
        "slim/psr7"            : "^1.7"
    } ,
    "minimum-stability" : "dev" ,
    "prefer-stable" : true ,
    "config" : {
        "allow-plugins" : {
            "phpdocumentor/shim" : true
        }
    }
}
